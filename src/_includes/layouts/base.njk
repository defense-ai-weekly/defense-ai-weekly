<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | {{ site.name }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <meta name="theme-color" content="#0d1117">
  <link rel="stylesheet" href="/assets/css/style.css">

  {% if canonical %}
  <link rel="canonical" href="{{ canonical }}">
  {% else %}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  {% endif %}

  <!-- Schema: Organization -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "{{ site.name }}",
    "url": "https://defenseaiweekly.com",
    "description": "{{ site.description }}",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "editor@defenseaiweekly.com",
      "contactType": "Editorial"
    }
  }
  </script>

  <!-- Schema: BreadcrumbList -->
  {% if breadcrumbs %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {% for crumb in breadcrumbs %}
      {
        "@type": "ListItem",
        "position": {{ loop.index }},
        "name": "{{ crumb.name }}",
        "item": "{{ crumb.url }}"
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  </script>
  {% endif %}

  <!-- Schema: FAQPage -->
  {% if faqs %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {% for faq in faqs %}
      {
        "@type": "Question",
        "name": "{{ faq.question | safe }}",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "{{ faq.answer | safe }}"
        }
      }{% if not loop.last %},{% endif %}
      {% endfor %}
    ]
  }
  </script>
  {% endif %}
  {% if pageSchema %}
  <script type="application/ld+json">
  {{ pageSchema | safe }}
  </script>
  {% endif %}
</head>
<body>
  <header class="def-header">
    <nav class="def-nav">
      <input type="checkbox" id="def-nav-toggle" class="def-nav-toggle" aria-label="Toggle navigation">
      <label for="def-nav-toggle" class="def-nav-toggle-label" aria-hidden="true">
        <span></span><span></span><span></span>
      </label>
      <a href="/" class="def-logo">
        <span class="def-logo__icon">⚡</span>
        {{ site.name }}
      </a>
      {% set categories = ["Intelligence", "Maritime", "OSINT", "Analysis"] %}
      <ul class="def-menu">
        {% for cat in categories %}
        <li class="def-menu__item">
          <a href="#" class="def-menu__link">{{ cat }}</a>
          <div class="def-dropdown">
            {% for article in collections.articles %}
            {% if article.data.category == cat %}
            <a href="{{ article.url }}" class="def-dropdown__item">{{ article.data.navTitle or article.data.title }}</a>
            {% endif %}
            {% endfor %}
          </div>
        </li>
        {% endfor %}
        <li class="def-menu__item">
          <a href="/about/" class="def-menu__link">About</a>
        </li>
      </ul>
    </nav>
  </header>

  <main class="def-main">
    <div class="def-article">
      {{ content | markdown | safe }}
    </div>
  </main>

  <footer class="def-footer">
    <div class="def-footer__inner">
      <div class="def-footer__brand">
        <div class="def-footer__logo">
          <span class="def-logo__icon">⚡</span>
          {{ site.name }}
        </div>
        <p class="def-footer__desc">
          A curated digest delivering actionable defense intelligence at the intersection of artificial intelligence, autonomous systems, and national security.
        </p>
      </div>
      <div>
        <h4 class="def-footer__col-title">Coverage</h4>
        <ul class="def-footer__links">
          <li><a href="/threat-intelligence/">Threat Intelligence</a></li>
          <li><a href="/maritime/">Maritime Domain</a></li>
          <li><a href="/osint/">OSINT</a></li>
          <li><a href="/signals-analysis/">Signals Analysis</a></li>
        </ul>
      </div>
      <div>
        <h4 class="def-footer__col-title">Resources</h4>
        <ul class="def-footer__links">
          <li><a href="/weekly-digest/">Weekly Digest</a></li>
          <li><a href="/analysis/">Analysis</a></li>
          <li><a href="/archive/">Archive</a></li>
          <li><a href="/subscribe/">Subscribe</a></li>
        </ul>
      </div>
      <div>
        <h4 class="def-footer__col-title">Contact</h4>
        <ul class="def-footer__links">
          <li><a href="mailto:editor@defenseaiweekly.com">editor@defenseaiweekly.com</a></li>
          <li><a href="/press/">Press Inquiries</a></li>
          <li><a href="/tips/">Tip Line</a></li>
        </ul>
      </div>
    </div>
    <div class="def-footer__bottom">
      <span>© 2026 {{ site.name }}. All rights reserved.</span>
      <div class="def-footer__legal">
        <a href="/privacy/">Privacy</a>
        <a href="/terms/">Terms</a>
      </div>
    </div>
  </footer>
</body>
</html>